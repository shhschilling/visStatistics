@article{Kozak:2018,
  title = {What's Normal Anyway? {{Residual}} Plots Are More Telling than Significance Tests When Checking {{{\textsc{ANOVA}}}} Assumptions},
  shorttitle = {What's Normal Anyway?},
  author = {Kozak, M. and Piepho, H.-P.},
  year = 2018,
  month = feb,
  journal = {J Agronomy Crop Science},
  volume = {204},
  number = {1},
  pages = {86--98},
  issn = {0931-2250, 1439-037X},
  doi = {10.1111/jac.12220},
  urldate = {2025-06-20},
  abstract = {Abstract                            We consider two questions important for applying analysis of variance (               ANOVA               ): Should normality be checked on the raw data or on the residuals (or is it immaterial which of the two approaches we take)? Should normality and homogeneity of variance be checked using significance tests or diagnostic plots (or both)? Based on two examples, we show that residuals should be used for model checking and that residual plots are better for checking               ANOVA               assumptions than statistical tests. We also discuss why one should be very cautious when using statistical tests to check the assumptions.},
  copyright = {http://onlinelibrary.wiley.com/termsAndConditions\#vor},
  langid = {english},
