@article{Kwak:2017,
  title = {Central Limit Theorem: The Cornerstone of Modern Statistics},
  shorttitle = {Central Limit Theorem},
  author = {Kwak, Sang Gyu and Kim, Jong Hae},
  year = 2017,
  month = apr,
  journal = {Korean Journal of Anesthesiology},
