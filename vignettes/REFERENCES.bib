@article{Eldar:2003p30,
  title = {Self-Enhanced Ligand Degradation Underlies Robustness of Morphogen Gradients.},
  author = {Eldar, Avigdor and Rosin, Dalia and Shilo, Ben-Zion and Barkai, Naama},
  year = 2003,
  month = oct,
  journal = {Developmental Cell},
  volume = {5},
  number = {4},
  pages = {635--646},
  abstract = {Morphogen gradients provide long-range positional information by extending across a developing field. To ensure reproducible patterning, their profile is invariable despite genetic or environmental fluctuations. Common models assume a morphogen profile that decays exponentially. Here, we show that exponential profiles cannot, at the same time, buffer fluctuations in morphogen production rate and define long-range gradients. To comply with both requirements, morphogens should decay rapidly close to their source but at a significantly slower rate over most of the field. Numerical search revealed two network designs that support robustness to fluctuations in morphogen production rate. In both cases, morphogens enhance their own degradation, leading to a higher degradation rate close to their source. This is achieved through reciprocal interactions between the morphogen and its receptor. The two robust networks are consistent with properties of the Wg and Hh morphogens in the Drosophila wing disc and provide novel insights into their function.},
  affiliation = {Department of Molecular Genetics, Weizmann Institute of Science, Rehovot 76100, Israel.},
  date-added = {2015-07-10T14:09:53GMT},
  date-modified = {2015-10-03T21:18:17GMT},
  langid = {english},
  pmid = {14536064},
  rating = {0},
  read = {Yes},
  uri = {papers3://publication/uuid/6E51147A-5364-4C02-8A7E-F00F6786338C},
  keywords = {Animals,Body Patterning,Computer Simulation,Dpp,Drosophila,Drosophila Leg,Drosophila Proteins,Expression,Gene Expression Regulation: Developmental,Green Fluorescent Proteins,Hedgehog,Hedgehog Proteins,Induction,Leg Imaginal Disc,Ligands,Long-Range Action,Luminescent Proteins,Mechanisms,Models: Biological,Morphogenesis,Neural Networks (Computer),Protein,Proto-Oncogene Proteins,Signal Transduction,Tissue Distribution,Wingless,Wnt1 Protein}
}

@article{Eldar:2005p13,
  title = {Interpreting Clone-Mediated Perturbations of Morphogen Profiles},
  author = {Eldar, Avigdor and Barkai, Naama},
