  pages = {693--695},
  publisher = {University of Zurich,Zurich School of Applied Sciences, University of Geneva},
  abstract = {Medical imaging plays a central role in the risk assessment of intracranial aneurysms, but to date a broadly accepted quantitative measure to assess the information encoded in these images is lacking. To close this gap, we relate established shape descriptors to expert assessments of aneurysm mor- phology. Firstly, we extract 3D models of aneurysms from 3D angiographies and calculate geometry indices and moment invariants describing size and shape of the aneurysm and its surrounding arteries. In a follow-up step these quantitative shape descriptors are compared to human assessments of qual- itative morphological characteristics like irregularity or the presence/absence of blebs. Preliminary results are based on 137 aneurysm models.}
