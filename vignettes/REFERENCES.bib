  author = {Kislinger, T and Cox, B and Kannan, A and Chung, C and Hu, {\relax PZ} and Ignatchenko, A and Scott, {\relax MS} and Gramolini, {\relax AO} and Morris, Q and Hallett, {\relax MT} and Rossant, J and Hughes, {\relax TR} and Frey, B and Emili, A},
  year = 2006,
